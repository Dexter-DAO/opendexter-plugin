# OpenDexter Plugin — Environment Variables
# These are fallbacks when plugin config UI isn't available (e.g. Pinata secrets)

# Solana wallet private key (base58) for USDC payments
# SVM_PRIVATE_KEY=

# EVM wallet private key (hex, 0x...) for Base/Polygon/Arbitrum/Optimism/Avalanche
# EVM_PRIVATE_KEY=

# Preferred payment network (default: auto-selects best-funded chain)
# DEFAULT_NETWORK=solana

# Max USDC per API call (default: 0.50)
# MAX_PAYMENT_USDC=0.50

# x402 facilitator URL (default: https://x402.dexter.cash)
# FACILITATOR_URL=https://x402.dexter.cash

# OpenDexter marketplace API (default: https://x402.dexter.cash/api/facilitator/marketplace/resources)
# MARKETPLACE_URL=
